{
  "mcpServers": {
    "grepai": {
      "command": "bash",
      "args": ["-c", "exec grepai mcp-serve --workspace \"$(basename \"$PWD\")\""]
    },
    "memory": {
      "type": "sse",
      "url": "http://192.168.1.172:8742/sse"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest", "--cdp-endpoint=http://localhost:9222"]
    }
  }
}
