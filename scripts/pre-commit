#!/bin/bash
# Git pre-commit hook: run tests + lint + typecheck
# Shows output only on failure

# Tests
output=$(make test-quick 2>&1)
status=$?

if [ $status -ne 0 ]; then
    echo "=================================="
    echo "❌ Tests failed. Commit blocked."
    echo "=================================="
    echo "$output"
    exit 1
fi

# Lint
output=$(make lint 2>&1)
status=$?

if [ $status -ne 0 ]; then
    echo "=================================="
    echo "❌ Lint failed. Commit blocked."
    echo "=================================="
    echo "$output"
    exit 1
fi

# Type check
output=$(make typecheck 2>&1)
status=$?

if [ $status -ne 0 ]; then
    echo "=================================="
    echo "❌ Type check failed. Commit blocked."
    echo "=================================="
    echo "$output"
    exit 1
fi

# Contract check (only if specs/api/ exists)
if [ -d "specs/api" ] && ls specs/api/*.yml specs/api/*.yaml 2>/dev/null | grep -q .; then
    output=$(make check-contract 2>&1)
    status=$?

    if [ $status -ne 0 ]; then
        echo "=================================="
        echo "❌ Contract check failed. Commit blocked."
        echo "=================================="
        echo "$output"
        exit 1
    fi
fi

# Success: silent
exit 0
